# Disabilita rate limiting per i test E2E
DISABLE_RATE_LIMIT=false

# Database remoto (Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME"

# JWT
JWT_SECRET="una-chiave-super-segreta-minimo-32-caratteri"
